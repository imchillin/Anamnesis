<UserControl x:Class="Anamnesis.Actor.Views.EquipmentEditor"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:Anamnesis.Actor.Views"
			 xmlns:converters="clr-namespace:Anamnesis.Actor.Converters"
			 mc:Ignorable="d"
			 d:DesignHeight="600">

	<Grid x:Name="ContentArea">
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>

		<local:ItemView Grid.Row="0" Grid.Column="0" ItemModel="{Binding DrawData.MainHand}" ExtendedViewModel="{Binding ModelObject.ChildObject, Mode=OneWay}"
						Slot="MainHand" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="0" Grid.Column="1" ItemModel="{Binding DrawData.OffHand}" ExtendedViewModel="{Binding ModelObject.ChildObject.NextSiblingObject}"
						Slot="OffHand" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="1" Grid.Column="0" ItemModel="{Binding DrawData.Equipment.Head}" Slot="Head"/>
		<local:ItemView Grid.Row="2" Grid.Column="0" ItemModel="{Binding DrawData.Equipment.Chest}" Slot="Body" />
		<local:ItemView Grid.Row="3" Grid.Column="0" ItemModel="{Binding DrawData.Equipment.Arms}" Slot="Hands" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="4" Grid.Column="0" ItemModel="{Binding DrawData.Equipment.Legs}" Slot="Legs"/>
		<local:ItemView Grid.Row="5" Grid.Column="0" ItemModel="{Binding DrawData.Equipment.Feet}" Slot="Feet" />
		<local:ItemView Grid.Row="1" Grid.Column="1" ItemModel="{Binding DrawData.Equipment.Ear}" Slot="Ears" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="2" Grid.Column="1" ItemModel="{Binding DrawData.Equipment.Neck}" Slot="Neck" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="3" Grid.Column="1" ItemModel="{Binding DrawData.Equipment.Wrist}" Slot="Wrists" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="4" Grid.Column="1" ItemModel="{Binding DrawData.Equipment.RFinger}" Slot="RightRing" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
		<local:ItemView Grid.Row="5" Grid.Column="1" ItemModel="{Binding DrawData.Equipment.LFinger}" Slot="LeftRing" IsEnabled="{Binding IsChocobo, Converter={StaticResource !B}, Mode=OneWay}"/>
	</Grid>
</UserControl>
